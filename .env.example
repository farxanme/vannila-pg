# IPG API origin (no trailing slash), e.g. http://localhost
# Leave empty to use mocks (see src/assets/js/mocks/ipgMocks.js)
VITE_IPG_BASE_URL=

# Set to "true" to force mocks even when VITE_IPG_BASE_URL is set
VITE_IPG_USE_MOCK=true

# Optional: full base for captcha API (default: /sep-auth/api/v1 — Vite proxies to https://auth.sep.ir)
# VITE_CAPTCHA_API_URL=https://auth.sep.ir/api/v1

# Optional: set to "true" to use mock captcha (image + audio; see src/assets/js/mocks/captchaMocks.js).
# When unset, empty VITE_IPG_BASE_URL (IPG mock mode) also enables captcha mocks.
# VITE_CAPTCHA_USE_MOCK=true

# Captcha code length (default: 6)
# VITE_CAPTCHA_CODE_LENGTH=6

# OTP constraints (defaults: min 6, max 12)
# VITE_OTP_MIN_LENGTH=6
# VITE_OTP_MAX_LENGTH=12

# Default card-input lock behavior during OTP cooldown (default: true)
# VITE_LOCK_CARD_NUMBER_DURING_OTP_COOLDOWN=true

# Mock timers (for easier manual testing).
# Accepts HH:MM:SS or seconds.
# VITE_MOCK_CARD_VIEW_TIMEOUT=00:10:00
# VITE_MOCK_RECEIPT_VIEW_TIMEOUT=00:01:00

# Mock transaction mode:
# - bill: prCode=40 and bills list is present
# - purchase: prCode=0 and bills list is empty
# VITE_MOCK_TRANSACTION_MODE=bill
